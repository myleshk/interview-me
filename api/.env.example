# ── Data Directory ──────────────────────────────────────
# Path to interview-me-data repo (identity.json + static/cv.pdf)
# In Docker: mounted volume at /app/data (leave default)
# For local dev: set to absolute path, e.g. /path/to/interview-me/data
DATA_DIR=

# ── DeepSeek API ─────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Qdrant (local Docker) ───────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ai_avatar

# ── Embedding Service ────────────────────────────────────
EMBEDDING_SERVICE_URL=http://embedding:8080
EMBEDDING_DIM=384

# ── Security ────────────────────────────────────────────
API_KEY=                  # Optional bearer token gate (leave empty to disable)
ALLOWED_ORIGINS=["*"]
CORS_ALLOW_LOCALHOST=true # Allow http(s)://localhost:* (required for frontend dev with credentials)

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── App ─────────────────────────────────────────────────
DEBUG=false
